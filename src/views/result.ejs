<%- include('partials/header', { title: '考试结果' }) %>
<div class="card mb-3">
  <div class="card-body">
    <h4 class="mb-3">考试结果（第<%= attempt.attemptNo %>次）</h4>
    <% const antiCheat = attempt.antiCheat || { isCheated: false, violationCount: 0 }; %>
    <% if (antiCheat.isCheated) { %>
      <div class="alert alert-danger">
        检测到违规操作，本次考试按作弊处理。原始得分 <strong><%= attempt.rawScore || 0 %></strong>，最终计分 <strong>0</strong>。
      </div>
    <% } %>
    <div class="row g-3">
      <div class="col-md-3"><div class="metric">总分<br><strong><%= attempt.totalScore %></strong></div></div>
      <div class="col-md-3"><div class="metric">原始分<br><strong><%= attempt.rawScore || attempt.totalScore %></strong></div></div>
      <div class="col-md-3"><div class="metric">合格线<br><strong><%= passScore %></strong></div></div>
      <div class="col-md-3"><div class="metric">错题数<br><strong><%= wrongCount %></strong></div></div>
    </div>
    <div class="small text-secondary mt-3">
      提交方式：<%= attempt.submittedReason === 'timeout' ? '超时自动提交' : (attempt.submittedReason === 'cheat' ? '违规强制提交' : '手动提交') %>，
      违规次数：<%= antiCheat.violationCount || 0 %>
    </div>
  </div>
</div>

<div class="result-detail-wrap">
  <h3 class="result-detail-title mb-3">答题明细</h3>

  <% attempt.questions.forEach((q, idx) => { %>
    <% const selectedArr = String(q.selectedAnswer || '').split(',').map(x => x.trim().toUpperCase()).filter(Boolean); %>
    <% const correctArr = String(q.correctAnswer || '').split(',').map(x => x.trim().toUpperCase()).filter(Boolean); %>

    <article class="answer-detail-card <%= q.isCorrect ? 'detail-right' : 'detail-wrong' %>">
      <div class="answer-detail-head">
        <span class="status-circle <%= q.isCorrect ? 'ok' : 'bad' %>"><%= q.isCorrect ? '✓' : '✕' %></span>
        <span class="answer-order"><%= idx + 1 %>.</span>
        <span class="answer-type-pill"><%= q.questionType === 'single' ? '单选' : '多选' %> • <%= q.score %>分</span>
      </div>

      <div class="answer-question"><%= q.content %></div>

      <div class="answer-options">
        <% q.options.forEach((op, i) => { const letter = String.fromCharCode(65 + i); %>
          <% const isCorrectOption = correctArr.includes(letter); %>
          <% const isSelectedOption = selectedArr.includes(letter); %>
          <% let cls = 'option-normal'; %>
          <% let marker = ''; %>
          <% if (isCorrectOption) { cls = 'option-correct'; marker = '✓'; } %>
          <% if (isSelectedOption && !isCorrectOption) { cls = 'option-wrong'; marker = '✕'; } %>

          <div class="answer-option-line <%= cls %>">
            <span><%= letter %>. <%= op %></span>
            <% if (marker) { %><span class="option-marker"><%= marker %></span><% } %>
          </div>
        <% }) %>
      </div>

      <div class="answer-summary-line">
        正确答案：<strong><%= q.correctAnswer || '无' %></strong>
        <span class="mx-1">|</span>
        你的答案：<strong><%= q.selectedAnswer || '未作答' %></strong>
      </div>
    </article>
  <% }) %>
</div>

<div class="mt-3"><a class="btn btn-outline-primary" href="/dashboard">返回我的学习考试</a></div>
<%- include('partials/footer') %>
