<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/"><img src="/logo.png" alt="Logo" />员工手册考试平台</a>
      <div class="collapse navbar-collapse show">
        <ul class="navbar-nav me-auto">
          <% if (currentUser && currentUser.role !== 'admin') { %>
            <li class="nav-item"><a class="nav-link" href="/dashboard">我的学习考试</a></li>
            <li class="nav-item"><a class="nav-link" href="/profile/password">修改密码</a></li>
          <% } %>
          <% if (currentUser && currentUser.role === 'admin') { %>
            <li class="nav-item"><a class="nav-link" href="/admin/users">用户管理</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/users/import">批量导入</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/config">基础配置</a></li>
            <li class="nav-item"><a class="nav-link" href="/admin/questions">题库管理</a></li>
            <li class="nav-item"><a class="nav-link" href="/reports/stores">门店统计</a></li>
          <% } %>
          <% if (currentUser && currentUser.role === 'manager') { %>
            <li class="nav-item"><a class="nav-link" href="/reports/stores">门店统计</a></li>
          <% } %>
        </ul>
        <div class="d-flex align-items-center gap-2 text-white small">
          <% if (currentUser) { %>
            <span><%= currentUser.name %>（<%= currentUser.roleLabel %>）</span>
            <form action="/logout" method="post">
              <button class="btn btn-outline-light btn-sm" type="submit">退出登录</button>
            </form>
          <% } else { %>
            <a class="btn btn-outline-light btn-sm" href="/login">登录</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>
  <main class="container py-4">
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type || 'info' %>"><%= flash.msg %></div>
    <% } %>
