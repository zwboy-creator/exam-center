<%- include('partials/header', { title: '初始化管理员' }) %>
<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h4 class="mb-3">初始化系统管理员</h4>
        <p class="text-secondary small">门店、部门、岗位按后台关联配置联动选择。</p>
        <form id="setupForm" method="post" action="/setup" class="row g-3">
          <div class="col-md-6"><label class="form-label">姓名</label><input class="form-control" name="name" required /></div>
          <div class="col-md-6"><label class="form-label">手机号（登录ID）</label><input class="form-control" name="phone" required /></div>
          <div class="col-md-6"><label class="form-label">密码</label><input class="form-control" name="password" type="password" required /></div>
          <div class="col-md-6"><label class="form-label">确认密码</label><input class="form-control" name="passwordConfirm" type="password" required /></div>
          <div class="col-md-4"><label class="form-label">所在门店</label><select class="form-select" name="storeId" required><option value="">请选择门店</option><% stores.forEach(s => { %><option value="<%= s.id %>"><%= s.name %></option><% }) %></select></div>
          <div class="col-md-4"><label class="form-label">部门</label><select class="form-select" name="departmentId" required><option value="">请选择部门</option><% departments.forEach(d => { %><option value="<%= d.id %>"><%= d.name %></option><% }) %></select></div>
          <div class="col-md-4"><label class="form-label">岗位</label><select class="form-select" name="positionId" required><option value="">请选择岗位</option><% positions.forEach(p => { %><option value="<%= p.id %>"><%= p.name %></option><% }) %></select></div>
          <div class="col-12"><button class="btn btn-primary" type="submit">创建管理员</button></div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('partials/user-linkage-script', { formId: 'setupForm', relations, departments, positions }) %>
<%- include('partials/footer') %>
