<%- include('partials/header', { title: '编辑题目' }) %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0">编辑题目 #<%= q.id %></h4>
  <a class="btn btn-outline-secondary" href="/admin/questions">返回题库</a>
</div>
<div class="card">
  <div class="card-body">
    <form method="post" action="/admin/questions/<%= q.id %>/edit" class="vstack gap-3">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">分类</label>
          <select class="form-select" name="category" required>
            <option value="universal" <%= q.category==='universal'?'selected':'' %>>通用岗</option>
            <option value="management" <%= q.category==='management'?'selected':'' %>>管理岗</option>
            <option value="service" <%= q.category==='service'?'selected':'' %>>服务岗</option>
            <option value="technical" <%= q.category==='technical'?'selected':'' %>>技术岗</option>
            <option value="spare_parts" <%= q.category==='spare_parts'?'selected':'' %>>配件/索赔岗</option>
            <option value="support" <%= q.category==='support'?'selected':'' %>>职能岗</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">题型</label>
          <select class="form-select" name="questionType" required>
            <option value="single" <%= q.questionType==='single'?'selected':'' %>>单选题</option>
            <option value="multiple" <%= q.questionType==='multiple'?'selected':'' %>>多选题</option>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">分值</label>
          <input class="form-control" type="number" name="score" value="<%= q.score %>" min="0" required />
        </div>
      </div>
      <div>
        <label class="form-label">题目内容</label>
        <textarea class="form-control" name="content" rows="3" required><%= q.content %></textarea>
      </div>
      <div>
        <label class="form-label">选项（JSON数组，如 ["A.选项","B.选项"]）</label>
        <input class="form-control" name="options" value="<%= JSON.stringify(q.options) %>" />
      </div>
      <div>
        <label class="form-label">答案（单选填 A，多选填 A,B）</label>
        <input class="form-control" name="answer" value="<%= q.answer %>" required />
      </div>
      <div>
        <button class="btn btn-primary" type="submit">保存修改</button>
      </div>
    </form>
  </div>
</div>
<%- include('partials/footer') %>
