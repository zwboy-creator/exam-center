<%- include('partials/header', { title: '手机号登录' }) %>
<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h4 class="mb-3">登录</h4>
        <% if (!hasAdmin) { %>
          <div class="alert alert-warning">系统还没有管理员，请先 <a href="/setup">初始化管理员</a>。</div>
        <% } %>
        <form method="post" action="/login" class="vstack gap-3">
          <div>
            <label class="form-label">手机号（登录ID）</label>
            <input class="form-control" name="phone" required />
          </div>
          <div>
            <label class="form-label">密码</label>
            <input class="form-control" name="password" type="password" required />
          </div>
          <button class="btn btn-primary" type="submit">登录</button>
        </form>
        <div class="mt-3 small">新员工请先 <a href="/register">注册</a></div>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
