<%- include('partials/header', { title: '登录 — 员工手册考试平台' }) %>
<div class="auth-card">
  <div class="card shadow-sm">
    <div class="card-body">
      <div class="auth-logo">
        <img src="/logo.png" alt="Logo" />
        <span>员工手册考试平台</span>
      </div>
      <% if (!hasAdmin) { %>
        <div class="alert alert-warning">系统还没有管理员，请先 <a href="/setup">初始化管理员</a>。</div>
      <% } %>
      <form method="post" action="/login" class="vstack gap-3">
        <div>
          <label class="form-label fw-500">手机号</label>
          <input class="form-control" name="phone" placeholder="请输入手机号" required />
        </div>
        <div>
          <label class="form-label fw-500">密码</label>
          <input class="form-control" name="password" type="password" placeholder="请输入密码" required />
        </div>
        <button class="btn btn-primary w-100 py-2" type="submit" style="font-size:1rem">登 录</button>
      </form>
      <div class="mt-3 text-center small text-secondary">新员工请先 <a href="/register">注册账号</a></div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
