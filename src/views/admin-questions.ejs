<%- include('partials/header', { title: '题库管理' }) %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0">题库管理</h4>
  <span class="badge text-bg-primary">总题数：<%= total %></span>
</div>
<div class="row g-3 mb-3">
  <div class="col-lg-6">
    <div class="card"><div class="card-body">
      <h6>导入题库CSV</h6>
      <form method="post" action="/admin/questions/import" enctype="multipart/form-data" class="vstack gap-2">
        <input class="form-control" type="file" name="file" accept=".csv" required />
        <div>
          <label class="form-label mb-1">导入模式</label>
          <select class="form-select" name="mode">
            <option value="replace">覆盖全部题库</option>
            <option value="merge">按题目ID合并</option>
          </select>
        </div>
        <button class="btn btn-primary" type="submit">导入题库</button>
      </form>
      <p class="small text-secondary mt-2 mb-0">CSV列：id,category,question_type,content,options,answer,score</p>
    </div></div>
  </div>
  <div class="col-lg-6">
    <div class="card"><div class="card-body">
      <h6>题库分布</h6>
      <table class="table table-sm"><thead><tr><th>分类</th><th>题型</th><th>数量</th></tr></thead><tbody>
        <% const catLabel = { management:'管理岗',service:'服务岗',technical:'技术岗',spare_parts:'配件/索赔岗',support:'职能岗',universal:'通用岗' };
           const typeLabel = { single:'单选题', multiple:'多选题' }; %>
        <% summary.forEach(r => { %><tr><td><%= catLabel[r.category] || r.category %></td><td><%= typeLabel[r.questionType] || r.questionType %></td><td><%= r.count %></td></tr><% }) %>
      </tbody></table>
    </div></div>
  </div>
</div>
<div class="card"><div class="card-body">
  <h6>最近30题</h6>
  <div class="table-responsive">
    <table class="table table-sm align-middle"><thead><tr><th>ID</th><th>分类</th><th>题型</th><th>题目</th><th>答案</th><th>分值</th></tr></thead><tbody>
      <% latestQuestions.forEach(q => { %><tr><td><%= q.id %></td><td><%= catLabel[q.category] || q.category %></td><td><%= typeLabel[q.questionType] || q.questionType %></td><td><%= q.content %></td><td><%= q.answer %></td><td><%= q.score %></td></tr><% }) %>
    </tbody></table>
  </div>
</div></div>
<%- include('partials/footer') %>
