# 复制为 .env 后填写（勿提交 .env）
# Supabase: Project Settings → Database → Connection string → URI
# 常驻 Node 服务请选「Session pool」或「Direct connection」，勿用 Transaction pool（与长事务不兼容）
DATABASE_URL=postgresql://postgres.xxx:你的密码@aws-0-xxx.pooler.supabase.com:5432/postgres

SESSION_SECRET=请使用足够长的随机字符串
TRUST_PROXY=1

# 仅当连接本机无 SSL 的 Postgres 时设为 0
# DATABASE_SSL=0
